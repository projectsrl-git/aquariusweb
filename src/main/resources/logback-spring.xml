<?xml version="1.0" encoding="UTF-8"?>
<!--
  AquariusWeb logging.

  Log directory comes from the Spring property `aquarius.log.dir`
  (set per environment in application-<env>.properties; overridable via the
  AQUARIUS_LOG_DIR env var or -Daquarius.log.dir=...). Falls back to ./logs.

  Rotation: a new file each day AND when the current file passes 10MB
  (SizeAndTimeBasedRollingPolicy). Archives kept 90 days, total capped at 3GB.
  Archived files are gzip-compressed.

  Two file appenders:
    - aquarius.log     : the whole application (level from logging.level.*)
    - aquarius-error.log: WARN/ERROR only, for quick incident triage.
  Console appender stays on so catalina.out still shows output.
-->
<configuration>

    <!-- Bridge Spring properties into logback. springProperty reads from the
         Spring Environment (so profile files and Maven filtering apply). -->
    <springProperty scope="context" name="LOG_DIR" source="aquarius.log.dir" defaultValue="./logs"/>
    <springProperty scope="context" name="APP_LEVEL" source="logging.level.com.aquarius" defaultValue="INFO"/>

    <property name="PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n"/>

    <!-- Console (captured by catalina.out) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder><pattern>${PATTERN}</pattern></encoder>
    </appender>

    <!-- Full application log: daily + size rotation, 90 days retention -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/aquarius.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archive/aquarius-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>90</maxHistory>
            <totalSizeCap>3GB</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        <encoder><pattern>${PATTERN}</pattern></encoder>
    </appender>

    <!-- Errors-only log for fast triage -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/aquarius-error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archive/aquarius-error-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>90</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        <encoder><pattern>${PATTERN}</pattern></encoder>
    </appender>

    <!-- Log di sistema attività web (utenti + tempi richieste/risposte) -->
    <appender name="ACTIVITY_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/aquarius-web-activity.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archive/aquarius-web-activity-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>90</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        <encoder><pattern>${PATTERN}</pattern></encoder>
    </appender>

    <!-- Logger dedicato: solo sul file attività, non sul log applicativo -->
    <logger name="AQUARIUS_ACTIVITY" level="INFO" additivity="false">
        <appender-ref ref="ACTIVITY_FILE"/>
    </logger>

    <!-- Application logger -->
    <logger name="com.aquarius" level="${APP_LEVEL}"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

</configuration>
