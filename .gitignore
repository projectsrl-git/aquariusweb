# Build
target/

# Runtime data (H2 system DB, logs) -- never commit runtime state
data/
logs/
*.log

# Per-environment secrets (real DB URLs / credentials) -- NEVER commit these.
# Ignore every real secrets file but KEEP the versioned template.
config/application-*.properties
!config/application-*.properties.template

# Commit message is delivered as a loose file per change, never tracked
COMMIT_MSG.txt

# IDE
.idea/
*.iml
.vscode/
.settings/
.project
.classpath
*.patch

# H2 database runtime files (never commit: contain data + credential hashes)
*.mv.db
*.trace.db
